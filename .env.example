APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=UTC

# LLM configuration
# LLM_BACKEND: mock | ollama | openai
LLM_BACKEND=openai
LLM_MODEL=gemini-2.0-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=

# WhatsApp channel configuration (adapter-ready)
# WHATSAPP_PROVIDER: mock | twilio | meta
WHATSAPP_PROVIDER=mock
WHATSAPP_PHONE_NUMBER=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Token persistence used by FastAPI OAuth callback
TOKEN_STORE_PATH=.runtime_tokens.json

# FastAPI Google OAuth settings
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional keys for future real provider wiring
# Gmail + Calendar OAuth app credentials (Google Cloud Console)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_ACCESS_TOKEN=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ACCESS_TOKEN=

# Web Search API credentials (provider-specific)
WEB_SEARCH_API_KEY=
WEB_SEARCH_ENGINE_ID=