APP_ENV=development
LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000
TOKEN_STORE_PATH=.runtime_tokens.json
DEFAULT_TIMEZONE=UTC

# Optional: disable skills by comma-separated names (example: email,calendar)
SKILLS_DISABLED=

# LLM configuration
# Supported values for LLM_BACKEND: gemini, openai, azure, ollama
LLM_BACKEND=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=
LLM_BASE_URL=

# Google OAuth (shared by Gmail/Calendar integrations)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_OAUTH_SERVICES=gmail,calendar

# Gmail credentials/tokens
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_ACCESS_TOKEN=
GMAIL_REFRESH_TOKEN=

# Google Calendar credentials/tokens
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# WhatsApp integration
# WHATSAPP_PROVIDER: twilio or meta
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=